{
  "name": "zencode",
  "version": "0.1.0",
  "description": "Mobile-first Termux-native coding agent. Simple REPL (default, best on phones) + optional rich Ink TUI. Defaults to Kimi 2.7 Code via Cloudflare + easy routing to open models like GLM (like OpenCode). Supports Bun (1.3.14+ has official Android/Termux support) or plain Node.js.",
  "type": "module",
  "bin": {
    "zencode": "./dist/cli.js"
  },
  "preferGlobal": true,
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "dev:tui": "tsx watch src/cli.ts --tui",
    "build": "tsc",
    "build:bun": "bun build src/cli.ts --outdir dist --target bun",
    "build:compile": "bun build src/cli.ts --compile --outfile zencode || echo 'Bun compile skipped (Bun not found or not needed)'",
    "start": "node dist/cli.js",
    "start:bun": "bun run dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "termux",
    "ai",
    "coding-agent",
    "terminal",
    "tui",
    "grok",
    "opencode"
  ],
  "author": "Aung Myat Moe",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "enquirer": "^2.4.1",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "openai": "^4.95.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aungmyatmoe/zencode"
  }
}
